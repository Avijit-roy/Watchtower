# =============================================================
# .env.example — Incident Command
# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.
# Every variable in use in the codebase MUST appear here.
# =============================================================

# --- Server ---------------------------------------------------
PORT=5000
NODE_ENV=development

# MongoDB Atlas free M0 — get this from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/incident-command?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-generated-locally
JWT_EXPIRES_IN=7d

# --- Client (Vite only exposes VITE_ prefixed vars) ----------
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# --- Worker (Phase 2) ----------------------------------------
WORKER_URL=http://localhost:5001/notify
NOTIFICATION_EMAIL=alerts@company.com

# Email via Nodemailer + free SMTP (Gmail app password or Brevo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-gmail-app-password

# Slack Incoming Webhook — create at api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/REAL
